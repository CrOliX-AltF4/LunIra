# Copy this file to .env in the directory where you run aiwb, then fill in your keys.
# At least one provider is required. Groq and Gemini are free to start.

# Groq — free tier available: https://console.groq.com
GROQ_API_KEY=

# Gemini — free tier available: https://aistudio.google.com
# Both GEMINI_API_KEY and GOOGLE_API_KEY are accepted (GEMINI_API_KEY takes priority)
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Anthropic Claude — paid: https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — paid: https://platform.openai.com
OPENAI_API_KEY=
