{
  "name": "lunatar",
  "version": "0.4.0",
  "description": "Multi-agent AI development pipeline CLI — forge production-ready code from a single intent",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "bin": {
    "lunatar": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "prepublishOnly": "npm run build && npm test"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "ai",
    "cli",
    "llm",
    "orchestration",
    "developer-tools",
    "open-source"
  ],
  "author": "CrOliX-AltF4",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CrOliX-AltF4/LunAtar.git"
  },
  "homepage": "https://github.com/CrOliX-AltF4/LunAtar#readme",
  "bugs": {
    "url": "https://github.com/CrOliX-AltF4/LunAtar/issues"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@google/generative-ai": "^0.24.1",
    "ajv": "^8.20.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "groq-sdk": "^1.1.2",
    "ink": "^7.0.2",
    "ink-text-input": "^6.0.0",
    "openai": "^6.37.0",
    "react": "^19.2.5"
  }
}
